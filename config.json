{
    "model": "PointNetConvNextFusionBase",
    "num_classes": 250,
    "use_normals": false,

    "data": {
        "point_clouds_dir": "preprocessed_point_clouds",
        "images_dir": "sketches_png/png"
    },

    "training": {
        "batch_size": 64,
        "num_epochs": 50,
        "early_stopping": 45,
        "learning_rate": 5e-05,
        "learning_rate_cnn": 5e-06,
        "weight_decay": 0.1,
        "label_smoothing": 0.1,
        "scheduler": "CosineAnnealingLR",
        "scheduler_T_max": 50,
        "scheduler_eta_min": 7e-08
    },

    "augmentation": {
        "rotation_range": 90,
        "scale_range": [0.5, 1.5],
        "translation_range": 0.2,
        "jitter_std": 0.008,
        "point_dropout_rate": 0.2
    },

    "checkpoint_name": "TUBerlin_checkpoints",
    "seed": 42
}
